# ── RedactGate admin UI configuration ────────────────────────────────────────
# Server-side base URL of the RedactGate FastAPI service (admin endpoints live here).
REDACTGATE_API_BASE=http://localhost:8080

# Admin token gating the /admin/* API. Sent as X-Admin-Token from the server only —
# it is NEVER exposed to the browser bundle.
REDACTGATE_ADMIN_TOKEN=

# Optional: public base used by client-side fetches. Defaults to the in-app
# /api/proxy route (which injects the admin token server-side). Set this only if you
# expose the admin API directly to the browser (not recommended).
# NEXT_PUBLIC_API_BASE=
