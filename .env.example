# ── RedactGate configuration ─────────────────────────────────────────────────
# Copy to `.env` and fill in. Generate the three 32-byte base64 keys with:
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"

ENVIRONMENT=dev
LOG_LEVEL=INFO

# ── Datastores (compose service hostnames shown; localhost for bare-metal) ────
DATABASE_URL=postgresql+asyncpg://redactgate:redactgate@localhost:5455/redactgate
REDIS_URL=redis://localhost:6390/0

# ── Which upstream LLM is used (one switch → every credit program) ────────────
# anthropic | openai | gemini | azure | bedrock | do-genai | ollama
AI_PROVIDER=ollama

ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
BEDROCK_REGION=us-east-1
DO_GENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1

# ── Detection ─────────────────────────────────────────────────────────────────
ENABLE_PRESIDIO=false          # requires the `ner` extra (pip install .[ner])
ENABLE_LLM_NER=false           # uses AI_PROVIDER for a structured EntitySpan[] pass
PRESIDIO_LANGUAGES=en
DEFAULT_PACK_CODES=GENERIC,CA,US,EU,UA

# ── Vault / crypto — REQUIRED in prod (base64, 32 bytes each) ────────────────
VAULT_MASTER_KEY=
FINGERPRINT_HMAC_KEY=
AUDIT_HMAC_KEY=
SESSION_TTL_HOURS=24

# ── Auth ──────────────────────────────────────────────────────────────────────
REQUIRE_API_KEY=true
ADMIN_TOKEN=
